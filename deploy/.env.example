# ===========================================
# ScenePin デプロイ設定
# ===========================================
# このファイルを .env にコピーして編集してください
# cp .env.example .env

# -------------------------------------------
# GitHub Container Registry
# -------------------------------------------
# GitHubユーザー名（ghcr.ioからpullするため）
GITHUB_USERNAME=your-github-username

# -------------------------------------------
# アプリケーション設定
# -------------------------------------------
# 公開ポート
APP_PORT=8080

# クライアントからアクセスするURL（サムネイルURL生成に使用）
# Tailscale経由の場合: http://<tailscale-ip>:8080
# ローカルの場合: http://localhost:8080
STORAGE_BASE_URL=http://localhost:8080

# -------------------------------------------
# データベース設定
# -------------------------------------------
POSTGRES_DB=scenepin
POSTGRES_USER=scenepin
POSTGRES_PASSWORD=scenepin

# -------------------------------------------
# ストレージ設定
# -------------------------------------------
# データ保存先（外付けHDDのパスを指定）
# 例: /mnt/external-hdd/scene-pin
DATA_PATH=./data

# -------------------------------------------
# Watchtower設定
# -------------------------------------------
# イメージ更新チェック間隔（秒）
WATCHTOWER_INTERVAL=300
